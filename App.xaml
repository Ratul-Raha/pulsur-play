<Application x:Class="PulsarPlay.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#252526"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#2D2D30"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#858585"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#4EC9B0"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#569CD6"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#CE9178"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#DCDCAA"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F14C4C"/>
        <SolidColorBrush x:Key="Border" Color="#3F3F46"/>
    </Application.Resources>
</Application>